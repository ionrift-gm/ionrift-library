<form class="ionrift patreon-menu-form">
    <header class="ionrift-patreon-header">
        <div class="ionrift-patreon-title">
            <i class="fab fa-patreon"></i>
            <span>Patreon Connection</span>
        </div>
        {{#if userTier}}
        <span class="ionrift-patreon-tier-badge">{{userTier}}</span>
        {{/if}}
    </header>

    {{#if expiryStatus}}
    <div class="ionrift-patreon-expiry ionrift-patreon-expiry--{{expiryStatus.state}}">
        <div class="ionrift-patreon-expiry-line">
            {{#if (eq expiryStatus.state "expired")}}
            <i class="fas fa-exclamation-triangle"></i>
            {{else if (eq expiryStatus.state "soon")}}
            <i class="fas fa-clock"></i>
            {{else}}
            <i class="fas fa-check-circle"></i>
            {{/if}}
            <span class="ionrift-patreon-expiry-label">{{expiryStatus.label}}</span>
            {{#unless (eq expiryStatus.state "ok")}}
            <button type="button" class="ionrift-patreon-btn-reconnect" data-action="reconnect">
                <i class="fas fa-sync-alt"></i> Reconnect
            </button>
            {{/unless}}
        </div>
        {{#if expiryStatus.hint}}
        <div class="ionrift-patreon-expiry-hint">{{expiryStatus.hint}}</div>
        {{/if}}
    </div>
    {{/if}}

    <div class="ionrift-ea-divider"></div>

    <div class="ionrift-ea-divider"></div>

    {{#if premiumModuleOffers.length}}
    <div class="ionrift-patreon-body">
        <h4 class="ionrift-ea-section-heading"><i class="fas fa-gem"></i> Premium Modules</h4>
        <p class="ionrift-premium-section-note">Full modules delivered through Patreon. Not on the public Foundry module browser.</p>

        {{#each premiumModuleOffers}}
        <div class="ionrift-ea-card ionrift-premium-card {{#unless isQualified}}ionrift-ea-card--locked{{/unless}}">
            <div class="ionrift-ea-card-icon"><i class="{{icon}}"></i></div>
            <div class="ionrift-ea-card-body">
                <div class="ionrift-ea-card-name">
                    {{title}}
                    <span class="ionrift-ea-version-pill">v{{version}}</span>
                    <span class="ionrift-ea-tier-pill">{{requiredTier}}+</span>
                    {{#if isGa}}
                    <span class="ionrift-premium-status-pill ionrift-premium-status-pill--ga">GA</span>
                    {{else}}
                    <span class="ionrift-premium-status-pill ionrift-premium-status-pill--ea">EA</span>
                    {{/if}}
                </div>
                {{#unless isQualified}}
                <div class="ionrift-ea-card-hint">Upgrade your tier to unlock this premium module</div>
                {{/unless}}
            </div>
            <div class="ionrift-ea-card-action">
                {{#if isQualified}}
                    {{#if isInstalled}}
                    <span class="ionrift-ea-installed"><i class="fas fa-check"></i> Installed</span>
                    {{else}}
                    <button data-action="install-premium" data-module-id="{{moduleId}}" data-version="{{version}}">
                        <i class="fas fa-download"></i> Install Now
                    </button>
                    {{/if}}
                {{else}}
                <span class="ionrift-ea-lock"><i class="fas fa-lock"></i> {{requiredTier}}+ required</span>
                {{/if}}
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}

    {{#if earlyAccessOffers.length}}
    <div class="ionrift-patreon-body">
        <h4 class="ionrift-ea-section-heading"><i class="fas fa-bolt"></i> Early Access</h4>

        {{#each earlyAccessOffers}}
        <div class="ionrift-ea-card {{#unless isQualified}}ionrift-ea-card--locked{{/unless}}">
            <div class="ionrift-ea-card-icon"><i class="{{icon}}"></i></div>
            <div class="ionrift-ea-card-body">
                <div class="ionrift-ea-card-name">
                    {{title}}
                    <span class="ionrift-ea-version-pill">v{{version}}</span>
                    <span class="ionrift-ea-tier-pill">{{requiredTier}}+</span>
                </div>
                {{#unless isQualified}}
                <div class="ionrift-ea-card-hint">Upgrade your tier to unlock early access</div>
                {{/unless}}
            </div>
            <div class="ionrift-ea-card-action">
                {{#if isQualified}}
                    {{#if isInstalled}}
                    <span class="ionrift-ea-installed"><i class="fas fa-check"></i> Installed</span>
                    {{else}}
                    <button data-action="install-ea" data-module-id="{{moduleId}}" data-version="{{version}}">
                        <i class="fas fa-download"></i> Install Now
                    </button>
                    {{/if}}
                {{else}}
                <span class="ionrift-ea-lock"><i class="fas fa-lock"></i> {{requiredTier}}+ required</span>
                {{/if}}
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}

    <div class="ionrift-ea-divider"></div>

    <footer class="ionrift-patreon-footer">
        <button type="button" class="ionrift-patreon-btn-refresh" data-action="refresh-registry">
            <i class="fas fa-sync-alt"></i> Check for Updates
        </button>
        <div class="ionrift-patreon-footer-spacer"></div>
        <button type="button" class="ionrift-patreon-btn-disconnect" data-action="disconnect">
            <i class="fas fa-unlink"></i> Disconnect
        </button>
        <button type="button" class="ionrift-patreon-btn-cancel" data-action="cancel">
            <i class="fas fa-times"></i> Cancel
        </button>
    </footer>
</form>
