<form class="{{cssClass}} ionrift-bug-report-form" autocomplete="off">
    <header class="ionrift-bug-report-header">
        <div class="ionrift-bug-report-title">
            <i class="fas fa-bug"></i>
            <span>Bug Report</span>
        </div>
    </header>

    <div class="ionrift-bug-report-body">
        <p class="ionrift-bug-report-lead">
            Collects a scrubbed snapshot of this world (module versions, recent console errors, optional note).
            Nothing is sent until you choose Send.
        </p>

        <div class="form-group">
            <label for="bug-report-note">Optional note</label>
            <textarea id="bug-report-note" name="note" rows="3"
                placeholder="What were you doing when something went wrong?"></textarea>
        </div>

        <p class="ionrift-bug-report-footnote" data-footnote>
            {{#if canSubmit}}
            You get a reference number to cite in
            <a href="{{discordUrl}}" target="_blank" rel="noopener">Discord</a> when you send.
            {{else}}
            Copy the report and paste it in
            <a href="{{discordUrl}}" target="_blank" rel="noopener">Discord</a>.
            {{/if}}
        </p>

        <div class="ionrift-bug-report-actions">
            <button type="button" class="ionrift-btn-secondary" data-action="copy">
                <i class="fas fa-copy"></i> Copy debug report
            </button>
            {{#if canSubmit}}
            <button type="button" class="ionrift-save-btn" data-action="send">
                <i class="fas fa-paper-plane"></i> Send report
            </button>
            {{/if}}
        </div>

        <div class="ionrift-bug-report-status is-hidden" data-status-panel aria-live="polite">
            <div class="ionrift-bug-report-status-line">
                <i class="status-icon fas" aria-hidden="true"></i>
                <span class="status-text"></span>
            </div>
            <p class="status-detail"></p>
        </div>
    </div>
</form>
